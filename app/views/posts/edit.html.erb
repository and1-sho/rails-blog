<h1>新規投稿</h1>

<% if @post.errors.any? %>
    <ul>
        <% @post.errors.full_messages.each do |message| %>
            <li><%= message %></li>
        <% end %>
    </ul>
<% end %>


<%= form_with model: @post do |f| %>
    <%= f.label :content, "内容" %>
    <%= f.text_area :content %>
    <%= f.submit "投稿する" %>
<% end %>

<%= link_to "投稿一覧に戻る", posts_path %>